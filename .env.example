# Host local (npm run dev fora do Docker)
DATABASE_URL="postgresql://fitmetrify:fitmetrify@localhost:5432/fitmetrify"
NEXT_PUBLIC_BASE_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# Produção (Railway): definir antes do build
# NEXT_PUBLIC_BASE_URL="https://fitmetrify-production.up.railway.app"

# Analytics (Etapa 2)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_POSTHOG_KEY=phc_XXXXXXXXXXXXXXXX
